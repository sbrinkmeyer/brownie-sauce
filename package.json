{
  "name": "brownie",
  "version": "2.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist:mac:x64": "electron-builder --mac dmg --x64",
    "dist:mac:arm64": "electron-builder --mac dmg --arm64",
    "dist:win:x64": "electron-builder --win nsis --x64",
    "dist:linux:appimage": "electron-builder --linux AppImage --x64"
  },
  "build": {
    "appId": "com.brownie.app",
    "productName": "Brownie",
    "compression": "maximum",
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Audio"
    },
    "files": [
      "main.js",
      "index.html",
      "renderer.js"
    ]
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
